# ============================================================
# SecureTrack Backend — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ============================================================

# Server
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://securetrack:securetrack_pass@localhost:5432/securetrack

# JWT Authentication
JWT_SECRET=replace-this-with-a-strong-random-secret
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
