{
  "dashboard": {
    "id": null,
    "uid": "securetrack-security",
    "title": "SecureTrack — DevSecOps Security Metrics",
    "tags": ["devsecops", "security", "pipeline"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Build Status (Success/Failure)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "ci_build_status",
            "legendFormat": "{{branch}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              { "type": "value", "options": { "0": { "text": "FAILED", "color": "red" }, "1": { "text": "PASSED", "color": "green" } } }
            ]
          }
        }
      },
      {
        "id": 2,
        "title": "Secrets Found (Gitleaks)",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "ci_gitleaks_findings",
            "legendFormat": "Secrets"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 1, "color": "red" }
              ]
            },
            "max": 10
          }
        }
      },
      {
        "id": 3,
        "title": "SAST High/Critical Findings",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "ci_semgrep_high",
            "legendFormat": "High/Critical"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 1, "color": "orange" },
                { "value": 3, "color": "red" }
              ]
            },
            "max": 20
          }
        }
      },
      {
        "id": 4,
        "title": "Image Critical CVEs",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "targets": [
          {
            "expr": "ci_trivy_critical",
            "legendFormat": "Critical CVEs"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 1, "color": "orange" },
                { "value": 5, "color": "red" }
              ]
            },
            "max": 30
          }
        }
      },
      {
        "id": 5,
        "title": "Test Coverage (%)",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 8, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "ci_test_coverage",
            "legendFormat": "Coverage"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 50, "color": "orange" },
                { "value": 70, "color": "green" }
              ]
            },
            "min": 0,
            "max": 100,
            "unit": "percent"
          }
        }
      },
      {
        "id": 6,
        "title": "Pipeline Duration (seconds)",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 16, "x": 8, "y": 4 },
        "targets": [
          {
            "expr": "ci_build_duration_seconds",
            "legendFormat": "{{branch}}"
          }
        ]
      },
      {
        "id": 7,
        "title": "Security Findings Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
        "targets": [
          {
            "expr": "ci_gitleaks_findings",
            "legendFormat": "Secrets"
          },
          {
            "expr": "ci_semgrep_high",
            "legendFormat": "SAST High/Crit"
          },
          {
            "expr": "ci_trivy_critical",
            "legendFormat": "Image Critical CVEs"
          }
        ]
      }
    ],
    "time": { "from": "now-30d", "to": "now" },
    "refresh": "5m"
  }
}
